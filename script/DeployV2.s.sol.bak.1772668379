pragma solidity ^0.8.23;

import "forge-std/Script.sol";
import "forge-std/console2.sol";
import "openzeppelin-contracts/contracts/governance/TimelockController.sol";

import "../src/NBCXV2.sol";
import "../src/TreasuryVault.sol";
import "../src/NBCXStakingV2.sol";

contract DeployV2 is Script {
    
    // NB_GOV_OWNERS_V3
    address internal constant OWNER1 = 0xfbBC8cb66CF2db89A8059f161ccDc3653B17ECba;
    address internal constant OWNER2 = 0x5d47Cc8675344E69FBAb0b34b89a83fAD3b0D4cb;
    address internal constant OWNER3 = 0xAb22B5283050E218f5B08878D2E5b7B7c9420978;
    uint256 internal constant WAD = 1e18;

    uint256 internal constant MAX_SUPPLY   = 100_000_000 * WAD;
    uint256 internal constant TREASURY     = 30_000_000 * WAD;
    uint256 internal constant ECOSYSTEM    = 20_000_000 * WAD;
    uint256 internal constant TEAM         = 10_000_000 * WAD;
    uint256 internal constant LIQUIDITY    = 5_000_000 * WAD;
    uint256 internal constant STAKING_POOL = 35_000_000 * WAD;

    uint256 internal constant ERA0_TOTAL = 17_500_000 * WAD;
    uint256 internal constant TIMELOCK_DELAY = 72 hours;

    function run() external {
        address GOVERNANCE = vm.envAddress("GOVERNANCE");
        // NB_GOV_ROLE_WIRING_V3
        address LIQ_WALLET = vm.envAddress("LIQ_WALLET");

        vm.startBroadcast();
        address deployer = msg.sender;

        address;
        proposers[0] = OWNER1;
        proposers[1] = OWNER2;
        proposers[2] = OWNER3;

        address;
        executors[0] = address(0);


        TimelockController timelock =
            new TimelockController(TIMELOCK_DELAY, proposers, executors, GOVERNANCE);

        TreasuryVault vault = new TreasuryVault(address(timelock));

        NBCXV2 token = new NBCXV2("Northbridge Token","NBCX",MAX_SUPPLY,deployer);
        NBCXStakingV2 staking = new NBCXStakingV2(address(token), block.timestamp, ERA0_TOTAL);

        token.approve(address(staking), STAKING_POOL);
        staking.fund(STAKING_POOL);
        token.transfer(address(vault), TREASURY + ECOSYSTEM + TEAM);
        token.transfer(LIQ_WALLET, LIQUIDITY);

        uint256 remainder = token.balanceOf(deployer);
        if (remainder > 0) {
        token.transfer(address(vault), remainder);
        }

        vm.stopBroadcast();

        console2.log("GOVERNANCE:", GOVERNANCE);
        console2.log("LIQ_WALLET:", LIQ_WALLET);
        console2.log("TIMELOCK:", address(timelock));
        console2.log("VAULT:", address(vault));
        console2.log("NBCX_V2:", address(token));
        console2.log("STAKING_V2:", address(staking));
    }
}
